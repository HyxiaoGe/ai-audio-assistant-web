# 模板文件：真实密钥由 orchestrator / secret manager 注入，切勿提交。
APP_ENV=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/audio_assistant
REDIS_URL=redis://localhost:6379/0

# Auth Service (统一认证) — audio-backend 通过 JWKS 校验 auth-service 签发的 RS256 JWT
# 本地开发：auth-service 跑在 localhost:8100 即可
# 生产/dev 服务器：auth-service 在 nano-banana-network，audio-backend 在 ai-audio-network，
#   两个 docker 网络不通，必须用公网 JWKS URL（走 Cloudflare，validator 内置 5 分钟缓存）
AUTH_SERVICE_URL=http://localhost:8100
# AUTH_SERVICE_JWKS_URL=  # 默认: {AUTH_SERVICE_URL}/.well-known/jwks.json
# 生产示例：AUTH_SERVICE_JWKS_URL=https://auth.seanfield.org/.well-known/jwks.json

# 静态数据字段级加密密钥（Fernet）：加密落库的 OAuth access/refresh token 等密钥。
# 生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 逗号分隔多把可轮换（第一把加密，全部解密）。留空=明文（仅本地开发，生产必须设置）。
FIELD_ENCRYPTION_KEY=

CONFIG_CENTER_DB_ENABLED=true
CONFIG_CENTER_CACHE_TTL=60
# Admin 权限已改为 JWT scopes（auth-service is_superuser）

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=audio-assistant
MINIO_USE_SSL=false

TENCENT_SECRET_ID=xxx
TENCENT_SECRET_KEY=xxx
TENCENT_REGION=ap-shanghai
TENCENT_ASR_APP_ID=
TENCENT_ASR_ENGINE_MODEL_TYPE=16k_zh
TENCENT_ASR_ENGINE_MODEL_TYPE_FILE_FAST=
TENCENT_ASR_CHANNEL_NUM=1
TENCENT_ASR_SOURCE_TYPE=0
TENCENT_ASR_RES_TEXT_FORMAT=2
TENCENT_ASR_SPEAKER_DIA=1
TENCENT_ASR_SPEAKER_NUMBER=2
TENCENT_ASR_POLL_INTERVAL=3
TENCENT_ASR_MAX_WAIT_SECONDS=300

ALIYUN_ACCESS_KEY_ID=xxx
ALIYUN_ACCESS_KEY_SECRET=xxx
ALIYUN_NLS_APP_KEY=xxx

# 火山引擎 ASR 配置（豆包语音）
VOLC_ASR_APP_ID=your-app-id
VOLC_ASR_ACCESS_TOKEN=your-access-token
VOLC_ASR_RESOURCE_ID=volc.seedasr.auc
VOLC_ASR_MODEL_NAME=bigmodel
# 仅对 volc.bigasr.auc 有效
VOLC_ASR_MODEL_VERSION=400
VOLC_ASR_LANGUAGE=zh-CN
VOLC_ASR_ENABLE_ITN=true
VOLC_ASR_SHOW_UTTERANCES=true
VOLC_ASR_POLL_INTERVAL=3
VOLC_ASR_MAX_WAIT_SECONDS=600

# 阿里云 OSS 配置（使用上面的 ALIYUN_ACCESS_KEY_ID/SECRET）
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_REGION=cn-hangzhou
OSS_BUCKET=your-bucket-name
OSS_USE_SSL=true

# 火山引擎 TOS 配置
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_REGION=cn-beijing
TOS_BUCKET=your-bucket-name
TOS_ACCESS_KEY=xxx
TOS_SECRET_KEY=xxx

# LLM Proxy（LiteLLM）：所有 chat / completion 都走这里
# 业务别名（chat-default/chat-premium/audio-structuring）在 LiteLLM 后台维护
LITELLM_BASE_URL=http://litellm-proxy:4000
LITELLM_API_KEY=sk-xxx
LITELLM_MODEL=chat-default
LITELLM_MAX_TOKENS=4096

# 转写润色并发的 LLM 调用上限（长转写分组并发润色，串行 ~8min → 并发 ~1-2min）。
# 必须低于 proxy_llm 熔断阈值（5），避免偶发空返回扎堆把熔断打 OPEN 连累摘要。默认 3，建议 ≤4。
POLISH_CONCURRENCY=3

# 摘要配图的并发生成上限（最多 6 张占位图，无界并发首发即撞 image-service 429）。
# 比润色更保守（默认 2）：429 不在客户端重试白名单、单张失败补不回；上限须低于 image_service 熔断阈值（5）。
IMAGE_GEN_CONCURRENCY=2

# OpenRouter 仅 RAG embedding 在用（text-embedding-3-small），其它 LLM 调用一律走 LiteLLM
OPENROUTER_API_KEY=xxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://your-site.example
OPENROUTER_APP_TITLE=ai-audio-assistant

# 远程 image-service（Gemini 系图像生成中间件，部署在 dev 服务器）
# 本地开发：IMAGE_SERVICE_BASE_URL=http://localhost:8090
# dev/生产 docker 网络内：IMAGE_SERVICE_BASE_URL=http://image-service:8090
IMAGE_SERVICE_BASE_URL=http://192.168.1.10:8090
IMAGE_SERVICE_API_KEY=
IMAGE_SERVICE_DEFAULT_MODEL=gemini-3-pro-image-preview

# Embedding / RAG 配置
OPENAI_API_KEY=xxx
OPENAI_BASE_URL=https://api.openai.com/v1
RAG_EMBEDDING_ENABLED=true
RAG_EMBEDDING_PROVIDER=openrouter
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIM=1536
RAG_CHUNK_SIZE=300
RAG_CHUNK_OVERLAP=50
RAG_EMBED_BATCH_SIZE=64

UPLOAD_ALLOWED_EXTENSIONS=mp3,mp4,wav,m4a,webm
UPLOAD_MAX_SIZE_BYTES=524288000
UPLOAD_PRESIGN_EXPIRES=300
MEDIA_DOWNLOAD_EXPIRES=3600

YOUTUBE_DOWNLOAD_DIR=./data/youtube
YOUTUBE_OUTPUT_TEMPLATE=%(id)s.%(ext)s
YOUTUBE_DOWNLOAD_FORMAT=bestaudio/best

# Google OAuth for YouTube API
# Get credentials from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
# Backend callback URL (must be registered in Google Cloud Console)
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/youtube/callback
# Frontend URL for redirect after OAuth
FRONTEND_URL=http://localhost:3000

STATS_CURRENCY=CNY
TASK_CLEANUP_DELAY_SECONDS=300

# PromptHub —— 摘要/章节划分/生图提示词正文的唯一来源（必填）
# 注意：本地 app/prompts/templates/ 只存配置（model_params/风格映射/i18n 标签），不含任何提示词正文。
# 未配置 BASE_URL/API_KEY 时不会回落本地，相关任务会直接失败（BusinessError），故生产必须配置且后端可达。
PROMPTHUB_BASE_URL=http://localhost:8000
PROMPTHUB_API_KEY=ph-xxx
PROMPTHUB_CACHE_TTL=300
# 预留键，当前代码未读取（无功能作用）
PROMPTHUB_IMAGE_GEN_PROJECT_ID=00000000-0000-0000-0000-000000000000
